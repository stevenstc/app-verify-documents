# ============================================================
# Docker Compose - Production Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- MongoDB ---
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change_this_strong_password
MONGO_DB_NAME=docu-chain

# --- JWT ---
# Generate with: openssl rand -hex 64
JWT_SECRET=change_this_to_a_very_long_random_secret

# --- BTTChain Blockchain ---
BTTC_RPC_URL=https://rpc.bt.io
BTTC_CONTRACT_ADDRESS=0x3674c435FEf8302650ae49D90B3c4236abcD7DBd
# WARNING: Keep this private key secret and never commit it
BTTC_PRIVATE_KEY=0xyour_wallet_private_key_here

# --- Subscription ---
MONTHLY_SUBSCRIPTION_BTT=1000

# --- CORS (optional, defaults to * which allows all origins) ---
# Set to your domain in production, e.g.: https://myapp.example.com
CORS_ORIGIN=*

# --- Port exposed on the host (the app will be accessible on this port) ---
# In Coolify this is managed by the proxy, set to 80 typically
APP_PORT=3000
